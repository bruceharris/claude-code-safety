{
  "name": "claude-code-safety",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Slide decks teaching safe use of Claude Code (hooks, sandbox, permissions, permission modes).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:diagrams": "for f in src/decks/*/diagrams/*.mmd; do mmdc -i \"$f\" -o \"${f%.mmd}.svg\" -c mermaid.config.json -b transparent; done"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "spectacle": "^10.1.6"
  },
  "devDependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "@types/mdx": "^2.0.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
